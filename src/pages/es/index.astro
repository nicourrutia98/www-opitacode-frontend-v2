---
import Layout from '../../layouts/Layout.astro';
import { ContactForm } from '../../components/ContactForm';
import productsData from '../../data/products.json';
import manifestoData from '../../data/manifesto.json';
import seriedadData from '../../data/seriedad.json';
import ProductCard from '../../components/ProductCard.astro';
import { t, type Lang } from '../../i18n';

const lang: Lang = 'es';
const products = productsData.products;
const manifesto = manifestoData;
const seriedad = seriedadData;
const flagship = products.find((p) => p.id === 'opita-os')!;
const otherProducts = products.filter((p) => p.id !== 'opita-os');
---

<Layout
  title="Opita Code | Software práctico para negocios reales"
  description="Construido desde Colombia con identidad local y ambición global. Ecosistema de productos de software."
  lang="es"
>
  <!-- ═══════════════════════════════════════════
       HERO
       ═══════════════════════════════════════════ -->
  <section class="hero container" aria-label="Introducción">
    <p class="hero__badge">Hecho en Colombia 🇨🇴</p>
    <img
      class="hero__symbol"
      src="/opita-symbol-light.svg"
      alt=""
      width="80"
      height="80"
      aria-hidden="true"
    />
    <h1 class="hero__tagline">
      <span>Software</span>
      <span>práctico</span>
      <span>para</span>
      <span>negocios</span>
      <span>reales</span>
    </h1>
    <p class="hero__subtitle">
      Desarrollo de software a medida, automatización de procesos y productos SaaS
      construidos desde Colombia con identidad local y ambición global.
    </p>
    <div class="hero__actions">
      <a href="#contact" class="cta-primary" data-cta-contact data-cta-section="hero">Conversemos de tu proyecto</a>
      <p class="hero__cta-desc">Respuesta en menos de 24h</p>
      <a href="#servicios" class="cta-secondary">Explora lo que hacemos</a>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       SERVICES
       ═══════════════════════════════════════════ -->
  <section id="servicios" class="section section--dark" aria-label="Servicios">
    <div class="container">
      <h2 class="section__title">Qué hacemos</h2>
      <p class="section__subtitle">
        Convertimos necesidades reales en sistemas funcionales.
        Estas son nuestras cuatro líneas de trabajo.
      </p>
      <div class="services-grid reveal-group">
        <article class="service-card reveal">
          <div class="service-card__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="16 18 22 12 16 6"/>
              <polyline points="8 6 2 12 8 18"/>
              <line x1="14" y1="4" x2="10" y2="20"/>
            </svg>
          </div>
          <h3 class="service-card__title">Desarrollo a Medida</h3>
          <p class="service-card__desc">
            Aplicaciones web, paneles administrativos, APIs, integraciones y plataformas
            digitales diseñadas para tu operación.
          </p>
        </article>
        <article class="service-card reveal">
          <div class="service-card__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2L2 7l10 5 10-5-10-5z"/>
              <path d="M2 17l10 5 10-5"/>
              <path d="M2 12l10 5 10-5"/>
            </svg>
          </div>
          <h3 class="service-card__title">Automatización</h3>
          <p class="service-card__desc">
            Conectamos tus herramientas, eliminamos tareas repetitivas y creamos
            flujos de trabajo eficientes que ahorran tiempo y reducen errores.
          </p>
        </article>
        <article class="service-card reveal">
          <div class="service-card__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="4" y="4" width="16" height="16" rx="2"/>
              <path d="M9 9h.01"/>
              <path d="M15 9h.01"/>
              <path d="M9 15h6"/>
            </svg>
          </div>
          <h3 class="service-card__title">Productos SaaS</h3>
          <p class="service-card__desc">
            Plataformas propias bajo suscripción: marketplaces, agregadores,
            sistemas de turnos y herramientas digitales para tu negocio.
          </p>
        </article>
        <article class="service-card reveal">
          <div class="service-card__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="23 7 16 12 23 17 23 7"/>
              <rect x="1" y="5" width="15" height="14" rx="2" ry="2"/>
            </svg>
          </div>
          <h3 class="service-card__title">Opita Developer</h3>
          <p class="service-card__desc">
            Construcción de tecnología en vivo: streams, tutoriales y desarrollo
            de productos reales desde Colombia para la comunidad.
          </p>
        </article>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       PROCESS
       ═══════════════════════════════════════════ -->
  <section id="proceso" class="section" aria-label="Proceso de trabajo">
    <div class="container">
      <h2 class="section__title">Cómo trabajamos</h2>
      <p class="section__subtitle">Tres pasos. De la idea al producto funcionando.</p>
      <div class="process-steps reveal-group">
        <article class="process-step reveal">
          <div class="process-step__number">01</div>
          <h3 class="process-step__title">Escuchamos</h3>
          <p class="process-step__desc">
            Nos sentamos contigo a entender tu negocio, tus objetivos y el problema
            real que necesitas resolver. Sin jerga técnica, sin suposiciones.
          </p>
        </article>
        <article class="process-step reveal">
          <div class="process-step__number">02</div>
          <h3 class="process-step__title">Construimos</h3>
          <p class="process-step__desc">
            Diseñamos, desarrollamos y entregamos en ciclos cortos con hitos claros.
            OpenSpec como contrato — siempre sabes en qué punto estamos y qué sigue.
          </p>
        </article>
        <article class="process-step reveal">
          <div class="process-step__number">03</div>
          <h3 class="process-step__title">Entregamos</h3>
          <p class="process-step__desc">
            Sistema funcionando, documentado y listo para escalar. Con soporte
            continuo y sin misterios — porque el software es una herramienta, no un adorno.
          </p>
        </article>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       FLAGSHIP — OPITA OS
       ═══════════════════════════════════════════ -->
  <section id="flagship" class="section section--dark" aria-label="Producto Flagship">
    <div class="container">
      <h2 class="section__title">El sistema que une todo lo demás</h2>
      <p class="section__subtitle">
        Construido con el mismo estándar que aplicamos a cada proyecto — y es la pieza
        que falta para que MiPymes colombianas no paguen 8 suscripciones.
      </p>
      <article class="project-featured reveal">
        <span class="project-featured__label">Flagship</span>
        <h3 class="project-featured__title">{flagship.name}</h3>
        <p class="project-featured__tagline">{flagship.tagline_es}</p>
        <p class="project-featured__desc">{flagship.description_es}</p>
        <div class="project-featured__tags">
          <span>CRM</span><span>Facturación DIAN</span><span>Nómina</span><span>Inventario</span><span>COP nativo</span><span>+57 first</span>
        </div>
        <a
          href="https://wa.me/573126126085?text=Hola%20Nicol%C3%A1s%2C%20me%20interesa%20Opita%20OS.%20%C2%BFMe%20cuentas%20m%C3%A1s%3F"
          target="_blank"
          rel="noopener noreferrer"
          class="project-featured__cta"
          data-cta-contact
          data-cta-section="flagship"
        >
          Quiero saber más
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </article>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       SERIEDAD (T8) — By the numbers + 3 credibility items
       ═══════════════════════════════════════════ -->
  <section id="seriedad" class="section" aria-label="Seriedad">
    <div class="container">
      <h2 class="section__eyebrow">Por los números</h2>
      <h3 class="section__title">{seriedad.seriedad.title_es}</h3>
      <p class="section__subtitle">{seriedad.seriedad.subtitle_es}</p>

      <ol class="metrics-grid" aria-label="Métricas operativas de Opita Code">
        {seriedad.metrics.map((m) => (
          <li class="metric-item reveal">
            <div class="metric-value">{m.value}</div>
            <div class="metric-label">{m.label_es}</div>
            {m.sublabel_es && <div class="metric-sublabel">{m.sublabel_es}</div>}
          </li>
        ))}
      </ol>

      <div class="seriedad-items reveal-group">
        {seriedad.seriedad.items.map((it) => (
          <article class="seriedad-item reveal">
            <div class="seriedad-item__icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={it.icon === 'shield' ? '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>' : it.icon === 'code' ? '<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>' : '<rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>'} />
            </div>
            <h4 class="seriedad-item__title">{it.title_es}</h4>
            <p class="seriedad-item__body">{it.body_es}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       MANIFESTO (T7)
       ═══════════════════════════════════════════ -->
  <section id="manifiesto" class="section" aria-label="Manifiesto">
    <div class="container">
      <h2 class="section__eyebrow">{manifesto.title_es}</h2>
      <h3 class="section__title">{manifesto.subtitle_es}</h3>

      <ol class="manifesto-list">
        {manifesto.principles.map((p) => (
          <li class="manifesto-item reveal">
            <span class="manifesto-number">{p.number}</span>
            <div>
              <h4 class="manifesto-title">{p.title_es}</h4>
              <p class="manifesto-body">{p.body_es}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       ECOSYSTEM (T6) — 8 product cards (excluye flagship)
       ═══════════════════════════════════════════ -->
  <section id="ecosystem" class="section section--light border-b" aria-label="Ecosistema de productos">
    <div class="container">
      <h2 class="section__eyebrow">Ecosistema</h2>
      <h3 class="section__title">9 productos en el ecosistema: 5 en vivo, 4 en construcción.</h3>
      <p class="section__subtitle">
        Aquí ves 8 (5 operativos + 3 en desarrollo). El flagship <strong>Opita OS</strong>
        lo destacamos arriba porque es la pieza que conecta todo. Cada producto con un
        propósito claro — no hacemos suites, hacemos herramientas que sabes cuándo abrir y para qué.
      </p>
      <div class="products-grid">
        {otherProducts.map((p) => <ProductCard product={p} lang={lang} />)}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       FOUNDER
       ═══════════════════════════════════════════ -->
  <section id="fundador" class="section section--dark" aria-label="Fundador">
    <div class="container">
      <div class="founder__card reveal">
        <div class="founder__photo">
          <img src="/founder.jpg" alt="Juan Nicolás Urrutia Salcedo — Fundador de Opita Code" width="200" height="200" />
        </div>
        <div class="founder__info">
          <h2 class="founder__name">Juan Nicolás Urrutia Salcedo</h2>
          <p class="founder__role">Fundador &amp; Desarrollador Principal</p>
          <p class="founder__bio">
            Colombiano, desarrollador de software y creador de Opita Code.
            Construyo tecnología práctica para negocios reales, hago streams
            en vivo sobre desarrollo y comparto lo que aprendo en el camino.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       CONTACT
       ═══════════════════════════════════════════ -->
  <section id="contact" class="section" aria-label="Contacto">
    <div class="container">
      <h2 class="section__title">Trabajemos juntos</h2>
      <p class="section__subtitle">
        ¿Tienes un proyecto en mente? Escríbenos y conversemos.
      </p>
      <div class="contact-grid">
        <div class="contact-channels">
          <a href="mailto:owner@opitacode.com" class="contact-channel">
            <span class="contact-channel__label">Email</span>
            <span class="contact-channel__value">owner@opitacode.com</span>
          </a>
          <a href="https://wa.me/573126126085" target="_blank" rel="noopener noreferrer" class="contact-channel">
            <span class="contact-channel__label">WhatsApp</span>
            <span class="contact-channel__value">+57 312 612 6085</span>
          </a>
          <a href="tel:+573126126085" class="contact-channel">
            <span class="contact-channel__label">Teléfono</span>
            <span class="contact-channel__value">+57 312 612 6085</span>
          </a>
        </div>
        <div class="contact-form">
          <h3 class="contact-form__title">Envíanos un mensaje</h3>
          <ContactForm client:load lang="es" />
        </div>
      </div>
    </div>
  </section>
</Layout>
