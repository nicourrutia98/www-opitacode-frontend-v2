---
import Layout from '../../layouts/Layout.astro';
import { ContactForm } from '../../components/ContactForm';
import productsData from '../../data/products.json';
import manifestoData from '../../data/manifesto.json';
import seriedadData from '../../data/seriedad.json';
import ProductCard from '../../components/ProductCard.astro';
import { t, type Lang } from '../../i18n';

const lang: Lang = 'en';
const products = productsData.products;
const manifesto = manifestoData;
const seriedad = seriedadData;
const flagship = products.find((p) => p.id === 'opita-os')!;
const otherProducts = products.filter((p) => p.id !== 'opita-os');
---

<Layout
  title="Opita Code | Practical software for real businesses"
  description="Built from Colombia with local identity and global ambition. Software ecosystem."
  lang="en"
>
  <!-- ═══════════════════════════════════════════
       HERO
       ═══════════════════════════════════════════ -->
  <section class="hero container" aria-label="Introduction">
    <p class="hero__badge">Made in Colombia 🇨🇴</p>
    <img
      class="hero__symbol"
      src="/opita-symbol-light.svg"
      alt=""
      width="80"
      height="80"
      aria-hidden="true"
    />
    <h1 class="hero__tagline">
      <span>Practical</span>
      <span>software</span>
      <span>for</span>
      <span>real</span>
      <span>businesses</span>
    </h1>
    <p class="hero__subtitle">
      Custom software development, process automation and SaaS products
      built from Colombia with local identity and global ambition.
    </p>
    <div class="hero__actions">
      <a href="#contact" class="cta-primary" data-cta-contact data-cta-section="hero">Let's talk about your project</a>
      <p class="hero__cta-desc">Reply in less than 24h</p>
      <a href="#servicios" class="cta-secondary">Explore what we do</a>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       SERVICES
       ═══════════════════════════════════════════ -->
  <section id="servicios" class="section section--dark" aria-label="Services">
    <div class="container">
      <h2 class="section__title">What we do</h2>
      <p class="section__subtitle">
        We turn real needs into working systems.
        These are our four lines of work.
      </p>
      <div class="services-grid reveal-group">
        <article class="service-card reveal">
          <div class="service-card__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="16 18 22 12 16 6"/>
              <polyline points="8 6 2 12 8 18"/>
              <line x1="14" y1="4" x2="10" y2="20"/>
            </svg>
          </div>
          <h3 class="service-card__title">Custom Development</h3>
          <p class="service-card__desc">
            Web applications, admin panels, APIs, integrations and digital
            platforms designed for your operation.
          </p>
        </article>
        <article class="service-card reveal">
          <div class="service-card__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2L2 7l10 5 10-5-10-5z"/>
              <path d="M2 17l10 5 10-5"/>
              <path d="M2 12l10 5 10-5"/>
            </svg>
          </div>
          <h3 class="service-card__title">Automation</h3>
          <p class="service-card__desc">
            We connect your tools, eliminate repetitive tasks and create
            efficient workflows that save time and reduce errors.
          </p>
        </article>
        <article class="service-card reveal">
          <div class="service-card__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="4" y="4" width="16" height="16" rx="2"/>
              <path d="M9 9h.01"/>
              <path d="M15 9h.01"/>
              <path d="M9 15h6"/>
            </svg>
          </div>
          <h3 class="service-card__title">SaaS Products</h3>
          <p class="service-card__desc">
            Subscription platforms: marketplaces, aggregators, booking systems
            and digital tools for your business.
          </p>
        </article>
        <article class="service-card reveal">
          <div class="service-card__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="23 7 16 12 23 17 23 7"/>
              <rect x="1" y="5" width="15" height="14" rx="2" ry="2"/>
            </svg>
          </div>
          <h3 class="service-card__title">Opita Developer</h3>
          <p class="service-card__desc">
            Live tech builds: streams, tutorials and real product development
            from Colombia for the community.
          </p>
        </article>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       PROCESS
       ═══════════════════════════════════════════ -->
  <section id="proceso" class="section" aria-label="Work process">
    <div class="container">
      <h2 class="section__title">How we work</h2>
      <p class="section__subtitle">Three steps. From idea to working product.</p>
      <div class="process-steps reveal-group">
        <article class="process-step reveal">
          <div class="process-step__number">01</div>
          <h3 class="process-step__title">Listen</h3>
          <p class="process-step__desc">
            We sit with you to understand your business, your goals and the
            real problem you need to solve. No jargon, no assumptions.
          </p>
        </article>
        <article class="process-step reveal">
          <div class="process-step__number">02</div>
          <h3 class="process-step__title">Build</h3>
          <p class="process-step__desc">
            We design, develop and deliver in short cycles with clear milestones.
            OpenSpec as the contract — you always know where we are and what's next.
          </p>
        </article>
        <article class="process-step reveal">
          <div class="process-step__number">03</div>
          <h3 class="process-step__title">Deliver</h3>
          <p class="process-step__desc">
            Working, documented system ready to scale. With ongoing support
            and no mysteries — software is a tool, not an ornament.
          </p>
        </article>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       FLAGSHIP — OPITA OS
       ═══════════════════════════════════════════ -->
  <section id="flagship" class="section section--dark" aria-label="Flagship product">
    <div class="container">
      <h2 class="section__title">The system that connects everything else</h2>
      <p class="section__subtitle">
        Built with the same standard we apply to every project — and the piece that's
        missing so Colombian SMBs don't pay 8 subscriptions.
      </p>
      <article class="project-featured reveal">
        <span class="project-featured__label">Flagship</span>
        <h3 class="project-featured__title">{flagship.name}</h3>
        <p class="project-featured__tagline">{flagship.tagline_en}</p>
        <p class="project-featured__desc">{flagship.description_en}</p>
        <div class="project-featured__tags">
          <span>CRM</span><span>DIAN invoicing</span><span>Payroll</span><span>Inventory</span><span>Native COP</span><span>+57 first</span>
        </div>
        <a
          href="https://wa.me/573126126085?text=Hi%20Nicol%C3%A1s%2C%20I%27m%20interested%20in%20Opita%20OS."
          target="_blank"
          rel="noopener noreferrer"
          class="project-featured__cta"
          data-cta-contact
          data-cta-section="flagship"
        >
          Tell me more
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </article>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       SERIEDAD (T8)
       ═══════════════════════════════════════════ -->
  <section id="seriedad" class="section" aria-label="Credibility">
    <div class="container">
      <h2 class="section__eyebrow">By the numbers</h2>
      <h3 class="section__title">{seriedad.seriedad.title_en}</h3>
      <p class="section__subtitle">{seriedad.seriedad.subtitle_en}</p>

      <ol class="metrics-grid" aria-label="Operational metrics of Opita Code">
        {seriedad.metrics.map((m) => (
          <li class="metric-item reveal">
            <div class="metric-value">{m.value}</div>
            <div class="metric-label">{m.label_en}</div>
            {m.sublabel_en && <div class="metric-sublabel">{m.sublabel_en}</div>}
          </li>
        ))}
      </ol>

      <div class="seriedad-items reveal-group">
        {seriedad.seriedad.items.map((it) => (
          <article class="seriedad-item reveal">
            <div class="seriedad-item__icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={it.icon === 'shield' ? '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>' : it.icon === 'code' ? '<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>' : '<rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>'} />
            </div>
            <h4 class="seriedad-item__title">{it.title_en}</h4>
            <p class="seriedad-item__body">{it.body_en}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       MANIFESTO (T7)
       ═══════════════════════════════════════════ -->
  <section id="manifiesto" class="section" aria-label="Manifesto">
    <div class="container">
      <h2 class="section__eyebrow">{manifesto.title_en}</h2>
      <h3 class="section__title">{manifesto.subtitle_en}</h3>

      <ol class="manifesto-list">
        {manifesto.principles.map((p) => (
          <li class="manifesto-item reveal">
            <span class="manifesto-number">{p.number}</span>
            <div>
              <h4 class="manifesto-title">{p.title_en}</h4>
              <p class="manifesto-body">{p.body_en}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       ECOSYSTEM (T6)
       ═══════════════════════════════════════════ -->
  <section id="ecosystem" class="section section--light border-b" aria-label="Product ecosystem">
    <div class="container">
      <h2 class="section__eyebrow">Ecosystem</h2>
      <h3 class="section__title">9 products in the ecosystem: 5 live, 4 in construction.</h3>
      <p class="section__subtitle">
        You see 8 below (5 live + 3 in development). The flagship <strong>Opita OS</strong>
        is featured above because it connects everything. Each product has a clear purpose —
        we don't make suites, we make tools you know when to open and why.
      </p>
      <div class="products-grid">
        {otherProducts.map((p) => <ProductCard product={p} lang={lang} />)}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       FOUNDER
       ═══════════════════════════════════════════ -->
  <section id="fundador" class="section section--dark" aria-label="Founder">
    <div class="container">
      <div class="founder__card reveal">
        <div class="founder__photo">
          <img src="/founder.jpg" alt="Juan Nicolás Urrutia Salcedo — Founder of Opita Code" width="200" height="200" />
        </div>
        <div class="founder__info">
          <h2 class="founder__name">Juan Nicolás Urrutia Salcedo</h2>
          <p class="founder__role">Founder &amp; Lead Developer</p>
          <p class="founder__bio">
            Colombian, software developer and creator of Opita Code.
            I build practical technology for real businesses, stream
            live development and share what I learn along the way.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       CONTACT
       ═══════════════════════════════════════════ -->
  <section id="contact" class="section" aria-label="Contact">
    <div class="container">
      <h2 class="section__title">Let's work together</h2>
      <p class="section__subtitle">
        Have a project in mind? Write to us and let's talk.
      </p>
      <div class="contact-grid">
        <div class="contact-channels">
          <a href="mailto:owner@opitacode.com" class="contact-channel">
            <span class="contact-channel__label">Email</span>
            <span class="contact-channel__value">owner@opitacode.com</span>
          </a>
          <a href="https://wa.me/573126126085" target="_blank" rel="noopener noreferrer" class="contact-channel">
            <span class="contact-channel__label">WhatsApp</span>
            <span class="contact-channel__value">+57 312 612 6085</span>
          </a>
          <a href="tel:+573126126085" class="contact-channel">
            <span class="contact-channel__label">Phone</span>
            <span class="contact-channel__value">+57 312 612 6085</span>
          </a>
        </div>
        <div class="contact-form">
          <h3 class="contact-form__title">Send us a message</h3>
          <ContactForm client:load lang="en" />
        </div>
      </div>
    </div>
  </section>
</Layout>
