---
import '../styles/global.css';
import ThemeToggle from '../components/ThemeToggle.astro';
import { t, type Lang } from '../i18n';

interface Props {
  title: string;
  description: string;
  lang: Lang;
  schema?: Record<string, any> | Record<string, any>[];
}

const { title, description, lang, schema } = Astro.props;
const year = new Date().getFullYear();

// REQ-SEO-3 + REQ-SEO-7: canonical + og:url limpios (sin query params, sin trailing slash)
const cleanPath = Astro.url.pathname.replace(/\/$/, '') || `/${lang}`;
const canonicalUrl = new URL(cleanPath, Astro.site).href;

// REQ-SEO-4: hreflang absolutos
const baseUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://opitacode.com';
const hreflangs = {
  es: `${baseUrl}/es`,
  en: `${baseUrl}/en`,
  'x-default': `${baseUrl}`,
};

// REQ-SEO-5: JSON-LD Organization + WebSite + ContactPoint (default)
const defaultSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': `${baseUrl}/#organization`,
      name: t(lang, 'meta.organization-name'),
      url: baseUrl,
      logo: `${baseUrl}/opita-horizontal-light.svg`,
      description: t(lang, 'meta.organization-tagline'),
      foundingDate: '2022-01-01',
      address: { '@type': 'PostalAddress', addressCountry: 'CO' },
      contactPoint: {
        '@type': 'ContactPoint',
        telephone: '+57-312-612-6085',
        contactType: 'sales',
        availableLanguage: ['Spanish', 'English'],
        areaServed: ['CO', 'US', 'MX', 'AR', 'PE', 'EC', 'VE', 'CL'],
      },
      sameAs: [
        'https://github.com/Opita-Code',
        'https://linkedin.com/company/opita-code',
        'https://youtube.com/@opitadeveloper',
      ],
    },
    {
      '@type': 'WebSite',
      '@id': `${baseUrl}/#website`,
      url: baseUrl,
      name: t(lang, 'meta.organization-name'),
      description: t(lang, 'meta.organization-tagline'),
      publisher: { '@id': `${baseUrl}/#organization` },
      inLanguage: ['es', 'en'],
    },
  ],
};

const finalSchema = schema ?? defaultSchema;
const ogImageUrl = new URL('/og-image.png', Astro.site).href;
---

<!doctype html>
<html lang={lang} class="scroll-smooth scroll-pt-24">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#F7F7F4" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#101010" media="(prefers-color-scheme: dark)" />

    <!-- Favicon set (legacy — 7 sizes + multi-res ICO) -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="48x48" href="/favicon-48x48.png" />
    <link rel="icon" type="image/png" sizes="64x64" href="/favicon-64x64.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192x192.png" />
    <link rel="icon" type="image/png" sizes="512x512" href="/favicon-512x512.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon-180x180.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="msapplication-TileColor" content="#F7F7F4" />

    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="canonical" href={canonicalUrl} />
    <meta name="robots" content="index, follow, max-image-preview:large" />

    <!-- SEO & Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content={lang === 'es' ? 'es_CO' : 'en_US'} />
    <meta property="og:site_name" content={t(lang, 'meta.organization-name')} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- i18n Alternate Links -->
    <link rel="alternate" hreflang="es" href={hreflangs.es} />
    <link rel="alternate" hreflang="en" href={hreflangs.en} />
    <link rel="alternate" hreflang="x-default" href={hreflangs['x-default']} />

    <!-- JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(finalSchema)} />

    <!-- Theme Manager (inline so dark/light applies before paint) -->
    <script is:inline>
      (function() {
        var t = localStorage.getItem('theme');
        if (t === 'dark' || (!t && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.classList.add('dark');
        } else {
          document.documentElement.classList.add('light');
        }
      })();
    </script>
  </head>
  <body>
    <!-- ── Navigation (legacy structure) ── -->
    <nav class="nav" aria-label={t(lang, 'header.main-nav')}>
      <div class="nav__inner">
        <a href={`/${lang}`} class="nav__brand" aria-label="Opita Code — inicio">
          <img
            class="nav__symbol dark:hidden"
            src="/opita-symbol-light.svg"
            alt=""
            width="32"
            height="32"
            loading="eager"
            aria-hidden="true"
          />
          <img
            class="nav__symbol hidden dark:block"
            src="/opita-symbol-dark.svg"
            alt=""
            width="32"
            height="32"
            loading="eager"
            aria-hidden="true"
          />
          <span class="nav__brand-name">Opita Code</span>
        </a>
        <ul class="nav__links">
          <li><a href={`/${lang}#servicios`} class="nav__link">{t(lang, 'nav.services')}</a></li>
          <li><a href={`/${lang}#ecosystem`} class="nav__link">{t(lang, 'nav.ecosystem')}</a></li>
          <li><a href={`/${lang}#fundador`} class="nav__link">{t(lang, 'nav.about')}</a></li>
          <li><a href={`/${lang}#contact`} class="nav__link">{t(lang, 'nav.contact')}</a></li>
        </ul>
        <div class="flex items-center gap-3">
          <div class="nav__lang" aria-label={t(lang, 'header.lang-switcher')}>
            <a href="/es" class={lang === 'es' ? 'is-active' : ''}>ES</a>
            <span class="nav__lang-sep" aria-hidden="true">/</span>
            <a href="/en" class={lang === 'en' ? 'is-active' : ''}>EN</a>
          </div>
          <ThemeToggle />
          <button
            type="button"
            id="nav__mobile-toggle"
            class="nav__mobile-toggle"
            aria-label={t(lang, 'header.open-menu')}
            aria-expanded="false"
            aria-controls="nav__mobile"
          >
            <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="3" y1="6" x2="21" y2="6" />
              <line x1="3" y1="12" x2="21" y2="12" />
              <line x1="3" y1="18" x2="21" y2="18" />
            </svg>
          </button>
        </div>
      </div>
    </nav>

    <!-- Mobile nav (hidden by default, toggled by JS) -->
    <div id="nav__mobile" class="nav__mobile" hidden>
      <ul class="nav__mobile-list">
        <li><a href={`/${lang}#servicios`} class="nav__mobile-link">{t(lang, 'nav.services')}</a></li>
        <li><a href={`/${lang}#ecosystem`} class="nav__mobile-link">{t(lang, 'nav.ecosystem')}</a></li>
        <li><a href={`/${lang}#fundador`} class="nav__mobile-link">{t(lang, 'nav.about')}</a></li>
        <li><a href={`/${lang}#contact`} class="nav__mobile-link">{t(lang, 'nav.contact')}</a></li>
        <li><a href="https://cuenta.opitacode.com" class="nav__mobile-link is-cta">{t(lang, 'nav.my-account')}</a></li>
      </ul>
    </div>

    <main>
      <slot />
    </main>

    <!-- ── Footer (legacy structure) ── -->
    <footer class="footer" aria-label={t(lang, 'footer.label')}>
      <div class="footer__inner">
        <div class="footer__lockup">
          <img
            class="footer__symbol"
            src="/opita-symbol-light.svg"
            alt=""
            width="64"
            height="64"
            loading="lazy"
            aria-hidden="true"
          />
          <span class="footer__brand-name">Opita Code</span>
        </div>
        <p class="footer__tagline">{t(lang, 'footer.tagline')}</p>

        <hr class="footer__divider" role="presentation" />

        <ul class="footer__legal">
          <li><a href="/es/legal/aviso" class="footer__legal-link">{t(lang, 'legal.aviso')}</a></li>
          <li><a href="/es/legal/ptd" class="footer__legal-link">{t(lang, 'legal.ptd')}</a></li>
          <li><a href="/es/legal/terminos" class="footer__legal-link">{t(lang, 'legal.terminos')}</a></li>
          <li><a href="/es/legal/reclamo" class="footer__legal-link">{t(lang, 'legal.reclamo')}</a></li>
        </ul>

        <p class="footer__copyright">
          © {year} Opita Code &middot; {t(lang, 'footer.founder-name')} &middot;
          <span class="country">{t(lang, 'footer.country')}</span>
        </p>

        <!-- Habeas Data + Trust signals (Ley 1581/2012) -->
        <div class="footer__trust">
          <div class="footer__trust-row">
            <span>📋 {t(lang, 'legal.habeas-data')}</span>
            <span class="footer__trust-row-sep" aria-hidden="true">·</span>
            <span>{t(lang, 'legal.estatuto')}</span>
            <span class="footer__trust-row-sep" aria-hidden="true">·</span>
            <span class="font-mono">{t(lang, 'legal.nit')}</span>
          </div>
          <p class="footer__channels-note">{t(lang, 'legal.sla')}</p>
        </div>
      </div>
    </footer>

    <!-- Mobile nav + Opita Telemetry (combined for performance) -->
    <script is:inline>
      (function() {
        // Mobile nav toggle
        var btn = document.getElementById('nav__mobile-toggle');
        var nav = document.getElementById('nav__mobile');
        if (btn && nav) {
          btn.addEventListener('click', function() {
            var open = nav.hasAttribute('hidden');
            if (open) { nav.removeAttribute('hidden'); } else { nav.setAttribute('hidden', ''); }
            btn.setAttribute('aria-expanded', String(open));
          });
          nav.querySelectorAll('a').forEach(function(a) {
            a.addEventListener('click', function() {
              nav.setAttribute('hidden', '');
              btn.setAttribute('aria-expanded', 'false');
            });
          });
        }

        // Opita Telemetry
        var API = 'https://api.opitacode.com/core/events/ingest';
        var PID = 'opitacode-web';
        var sid = sessionStorage.getItem('opita_session_id');
        if (!sid) { sid = (crypto && crypto.randomUUID) ? crypto.randomUUID() : String(Date.now()); sessionStorage.setItem('opita_session_id', sid); }
        var q = [];
        function t(type, data) {
          q.push({ type: type, source: 'landing', timestamp: new Date().toISOString(), data: data || {} });
          if (q.length >= 10) f();
        }
        function f() {
          if (!q.length) return;
          var p = JSON.stringify({ events: q.splice(0), sessionId: sid, productId: PID });
          if (navigator.sendBeacon) { navigator.sendBeacon(API, p); }
          else { fetch(API, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: p, keepalive: true }).catch(function() {}); }
        }
        var ps = new URLSearchParams(location.search);
        t('page_view', {
          url: location.pathname,
          referrer: document.referrer || '',
          utm_source: ps.get('utm_source'),
          utm_medium: ps.get('utm_medium'),
          utm_campaign: ps.get('utm_campaign')
        });
        t('session_start', { url: location.pathname });
        document.addEventListener('click', function(e) {
          var el = e.target.closest('a[href*="#contact"], a[data-cta-contact]');
          if (!el) return;
          var text = (el.textContent || '').trim().slice(0, 80);
          var href = el.getAttribute('href') || '';
          var section = (el.getAttribute('data-cta-section') || 'hero').slice(0, 32);
          t('cta_click', { button: text, href: href, source_section: section, lang: document.documentElement.lang });
        });
        document.addEventListener('visibilitychange', function() { if (document.visibilityState === 'hidden') f(); });
        window.addEventListener('pagehide', f);

        // Hero entrance — fires once per session
        var hero = document.querySelector('.hero');
        if (hero && !sessionStorage.getItem('opita-hero-animated')) {
          sessionStorage.setItem('opita-hero-animated', '1');
          hero.classList.add('hero-animate-in');
        }

        // Scroll reveals — IntersectionObserver, gated by reduced-motion
        if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
          var els = document.querySelectorAll('.reveal, .reveal-group');
          if (els.length) {
            var observer = new IntersectionObserver(function(entries) {
              entries.forEach(function(entry) {
                if (!entry.isIntersecting) return;
                var el = entry.target;
                if (el.classList.contains('reveal-group')) {
                  el.querySelectorAll('.reveal').forEach(function(child, i) {
                    child.style.setProperty('transition-delay', (i * 80) + 'ms');
                    child.classList.add('reveal--visible');
                  });
                } else {
                  el.classList.add('reveal--visible');
                }
                observer.unobserve(el);
              });
            }, { threshold: 0.15 });
            els.forEach(function(el) { observer.observe(el); });
          }
        }
      })();
    </script>
  </body>
</html>
