---
/**
 * ProductCard — v6 (round 6)
 * Rediseño limpio inspirado en el legacy:
 * - Carátula SUTIL: solo status badge + corner icon, sin logo gigante, sin iniciales
 * - Sin patrón de fondo (lo era noise visual)
 * - Sin "by Opita Code" (duplicaba el nombre de la card)
 * - Trust signal en monospace, sin bullets
 * - CTA claro con jerarquía visual
 *
 * Styles base en global.css (single source of truth).
 */
import { t, type Lang } from '../i18n';
import type { Product } from '../data/types';
import { ctaUrlForProduct } from '../data/types';
import caratulas from '../data/caratulas.json';
import { ICON_PATHS } from '../lib/icon-paths';

interface Props {
  product: Product;
  lang: Lang;
}

const { product, lang } = Astro.props;

const status = product.status;
const ctaUrl = ctaUrlForProduct(product, lang);
const isWhatsApp = ctaUrl.startsWith('https://wa.me/');
const ctaLabel = lang === 'es' ? product.cta_label_es : product.cta_label_en;
const tagline = lang === 'es' ? product.tagline_es : product.tagline_en;
const description = lang === 'es' ? product.description_es : product.description_en;

const colorClass = `caratula--${product.color}`;
const caratulaDef = (caratulas as any)[product.id] || {};
const layout = caratulaDef.layout || 'default';
const trustSignal = lang === 'es' ? caratulaDef.trust_es : caratulaDef.trust_en;

// LIVE badge: badge discreto
const liveBadge = lang === 'es' ? 'EN VIVO' : 'LIVE';
const waitingBadge = lang === 'es' ? 'EN DESARROLLO' : 'IN DEVELOPMENT';
const showStatusBadge = status === 'live' ? liveBadge : waitingBadge;
const isLive = status === 'live';

// CTA variant per layout (waitlist outlined, others default)
const ctaVariant = layout === 'waitlist' ? 'outline' : 'default';
const iconPath = ICON_PATHS[product.icon] || ICON_PATHS.layers;
---

<article
  class={`product-card product-card--${layout} reveal`}
  data-product-id={product.id}
  data-product-status={status}
  data-layout={layout}
>
  <!-- Carátula sutil: solo color de fondo + status badge + corner icon -->
  <div class={`caratula ${colorClass} caratula--clean`} aria-hidden="true">
    <!-- Status badge discreto (top-left) -->
    <span class={`caratula__status caratula__status--${isLive ? 'live' : 'wip'}`} aria-label={showStatusBadge}>
      <span class="caratula__status-dot"></span>
      {showStatusBadge}
    </span>

    <!-- Icon corner mark (top-right) -->
    <div class="caratula__corner">
      <svg class="caratula__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" set:html={iconPath} />
    </div>
  </div>

  <div class="product-card__body">
    <h3 class="product-card__title">{product.name}</h3>
    <p class="product-card__tagline">{tagline}</p>

    <!-- Trust signal: monospace, sin bullet -->
    {trustSignal && (
      <div class="product-card__trust">
        <span class="product-card__trust-text">{trustSignal}</span>
      </div>
    )}

    <p class="product-card__desc">{description}</p>

    <a
      href={ctaUrl}
      target={isWhatsApp ? '_blank' : undefined}
      rel={isWhatsApp ? 'noopener noreferrer' : undefined}
      data-product-cta={product.id}
      data-cta-contact
      data-cta-section="ecosystem"
      class={`product-card__cta product-card__cta--${ctaVariant}`}
      aria-label={`${ctaLabel} — ${product.name}`}
    >
      <span class="product-card__cta-text">{ctaLabel}</span>
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="product-card__cta-arrow" aria-hidden="true">
        <path d="M5 12h14M12 5l7 7-7 7"/>
      </svg>
    </a>
  </div>
</article>
